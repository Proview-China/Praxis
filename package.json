{
  "name": "praxis",
  "version": "0.1.0",
  "private": true,
  "description": "Blank-slate reboot scaffold for Praxis.",
  "type": "module",
  "packageManager": "npm@11.6.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm run build",
    "start": "node dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
